</event>
<event name="ENCOUNTER_ROCK_LOSTSUN_REGULAR">
	<text load="TEXT_ENCOUNTER_ROCK_LOSTSUN" />
	<ship load="SHIP_ROCK_FIGHT" hostile="true" /> 
	<choice hidden="true">
		<text>继续。</text>
		<event load="COMBAT_CHECK" />
