\\\\\\\\\\\\\\\\\\\\\\\\
-->
<event name="FUEL_FREEMANTIS_CONFUSED">
	<text>幸运的是，看起来有一艘自由螳螂舰船碰见你了，并立即呼叫。"啊，是联邦！你看起来遇难了。需要物资吗？我们送一些过去！希望与你交易一些燃料。"</text>
	<ship load="SHIP_FREEMANTIS_GENERIC" hostile="false" />
	<choice>
		<text>购买一些弹药。</text>
		<event>
			<item_modify>
				<item type="fuel" min="-5" max="-5" />
				<item type="missiles" min="10" max="10" />
			</item_modify>
		</event>
	</choice>
	<choice>
		<text>买一些无人机部件。</text>
		<event>
			<item_modify>
				<item type="fuel" min="-5" max="-5" />
				<item type="drones" min="10" max="10" />
			</item_modify>
		</event>
	</choice>
	<choice hidden="true">
		<text>但...我们需要燃料。</text>
		<event>
			<text>"哦？价格太高了？好好，我们可以降价！"</text>
			<choice>
				<text>购买一些弹药。</text>
				<event>
					<item_modify>
						<item type="fuel" min="-1" max="-1" />
						<item type="missiles" min="10" max="10" />
					</item_modify>
				</event>
			</choice>
			<choice>
				<text>买一些无人机部件。</text>
				<event>
					<item_modify>
						<item type="fuel" min="-1" max="-1" />
						<item type="drones" min="10" max="10" />
					</item_modify>
				</event>
			</choice>
			<choice hidden="true">
				<text>我们没有燃料！</text>
				<event>
					<text>"哦，好的我的锅。那么可以免费送你一些物资！"</text>
					<choice>
						<text>拿一些免费弹药。</text>
						<event>
							<item_modify>
								<item type="missiles" min="3" max="3" />
							</item_modify>
						</event>
					</choice>
					<choice>
						<text>拿一些免费无人机部件。</text>
						<event>
							<item_modify>
								<item type="drones" min="3" max="3" />
							</item_modify>
						</event>
					</choice>
					<choice hidden="true">
						<text>你们有一些多余的燃料吗？</text>
						<event>
							<text>"哈？没，我们用尽最后一点燃料跃迁至此。那你意思是你不想要物资吗？"</text>
							<choice>
								<text>不，我们还是想要一些。</text>
								<event>
									<text>"给你！"自由螳螂送你一些物质。</text>
									<item_modify>
										<item type="drones" min="2" max="2" />
										<item type="missiles" min="2" max="2" />
									</item_modify>
									<choice hidden="true">
										<text>继续。</text>
										<event>
											<text>"哦，再拿一些燃料吧朋友！"</text>
											<item_modify>
												<item type="fuel" min="3" max="3" />
											</item_modify>
											<choice hidden="true">
												<text>等下，你们不是说你们也用完燃料了吗？</text>
												<event>
													<text>"什么？不知道你什么意思。不论如何，再见！"自由螳螂舰船跃迁。</text>
													<instantEscape />
												</event>
											</choice>
										</event>
									</choice>
								</event>
							</choice>
							<choice hidden="true">
								<text>不，谢谢。</text>
								<event>
									<text>"哈？好吧！"自由螳螂舰船跃迁，让你大为困惑。</text>
									<instantEscape />
								</event>
							</choice>
						</event>
					</choice>
